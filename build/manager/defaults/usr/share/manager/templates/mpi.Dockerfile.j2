FROM {{ base_os }}

ARG CACHEBUST=1
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        wget \
        gnupg \
        systemd \
        systemd-sysv \
        udev \
        dbus \
        procps \
        iproute2 \
        net-tools \
        sudo \
        locales \
        tzdata \
        efibootmgr \
        openssh-server \
        os-prober \
        kmod \
        pciutils \
        console-setup \
        parted \
        nano \
        bzip2 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN . /etc/os-release && \
    case "$ID" in \
        ubuntu) KERNEL_PKG="linux-generic" ;; \
        debian) KERNEL_PKG="linux-image-amd64" ;; \
        *)      KERNEL_PKG="linux-image-generic" ;; \
    esac && \
    apt-get update && \
    apt-get install -y --no-install-recommends "$KERNEL_PKG" && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN apt-get update && \
    echo "grub-pc grub-pc/install_devices_empty boolean true" | debconf-set-selections && \
    echo "grub-pc grub-pc/install_devices string " | debconf-set-selections && \
    apt-get install -y --no-install-recommends grub-pc-bin grub-common grub-efi-amd64-bin && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN echo "en_US.UTF-8 UTF-8" > /etc/locale.gen && locale-gen

ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8
ENV TZ=UTC

RUN ln -fs /usr/share/zoneinfo/UTC /etc/localtime && \
    dpkg-reconfigure -f noninteractive tzdata

RUN install -d -m 0755 /etc/{{ prefix }} && \
    echo '{"server":"{{ server }}","project":"{{ project_slug }}","project_name":"{{ project_name }}","prefix":"{{ prefix }}"}' > /etc/{{ prefix }}/project.json

RUN systemctl enable systemd-networkd.service 2>/dev/null; \
    systemctl enable systemd-resolved.service 2>/dev/null; \
    exit 0

RUN adduser --disabled-password --gecos "" mcs && \
    echo "mcs:mcs" | chpasswd && \
    usermod -aG sudo,users mcs && \
    mkdir -p /home/mcs && \
    chown mcs:mcs /home/mcs && \
    chmod 700 /home/mcs

CMD ["/sbin/init"]

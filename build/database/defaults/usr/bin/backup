#!/bin/bash

_LOG=/var/log/backup

{
    _PATH="${DATASHARE_MOUNT_PATH}/dump"

    DUMP_FILE="${1:-migasfree.sql}"

    mkdir -p "$_PATH" || :

    PGPASSWORD=$(cat "/run/secrets/${STACK}_superadmin_pass")
    export PGPASSWORD
    echo "Time zone: $TZ"


    # DUMP DATABASE
    echo "$(date) Dump database to $_PATH/$DUMP_FILE ..."
    if pg_dump -h "$POSTGRES_HOST" -p "$POSTGRES_PORT" \
        "$POSTGRES_DB" -U "$POSTGRES_USER" > "$_PATH/$DUMP_FILE"
    then
        echo "$(date) Done!"
    else
        echo "$(date) ERROR !!! "
    fi

    echo ""
    echo "-----------------------------------------"
    echo "$(date) VACUUM database $POSTGRES_DB..."
    if /bin/su postgres -c "psql -h '$POSTGRES_HOST' -p '$POSTGRES_PORT' -U '$POSTGRES_USER' -d '$POSTGRES_DB' -c 'VACUUM VERBOSE'"
    then
        echo "$(date) VACUUM Done!"
    else
        echo "$(date) VACUUM ERROR !!! "
    fi
} 2>&1 | tee "$_LOG"
